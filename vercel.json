{
  "rewrites": [
    {
      "source": "/api/aqara/:path*",
      "destination": "https://open-kr.aqara.com/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/aqara/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Appid,Keyid,Nonce,Time,Sign,Accesstoken,Lang" }
      ]
    }
  ]
}